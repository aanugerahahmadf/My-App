# Clerk Authentication
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_key_here

# Laravel Backend API
# PENTING: Ganti dengan IP address komputer yang menjalankan Laravel
# Jangan gunakan localhost atau 127.0.0.1 karena tidak bisa diakses dari mobile device
# Gunakan IP local network (contoh: 192.168.x.x)
EXPO_PUBLIC_API_URL=http://192.168.100.63:8000/api

# Cara mendapatkan IP address:
# Windows: buka CMD, ketik 'ipconfig', lihat IPv4 Address
# Mac/Linux: buka Terminal, ketik 'ifconfig' atau 'ip addr'
#
# Pastikan:
# 1. Mobile device dan server Laravel di network WiFi yang sama
# 2. Laravel running dengan: php artisan serve --host=0.0.0.0 --port=8000
# 3. Firewall tidak block port 8000
